@startuml
'https://plantuml.com/class-diagram

skinparam style strictuml
skinparam classAttributeIconSize 0
skinparam classFontStyle Bold
hide enum methods


package src{
    class LabyrintheApp{
        static main(args : String[])
    }

    package controller{
        class LabyrintheController{
        + bougerLigne(plateau : Plateau)
        }
        class Background{
        + lancementJeu() : Boolean
        }
    }
    package helpers{
        class ImageHelper{
            + static merge(backgroundPath : String, foregroundPaths : String) : BufferedImage
            + static rotate(original : BufferedImage,angle : double) : BufferedImage
            + static rotateClockwise(original : BufferedImage ) : BufferedImage
            + static rotateCounterClockwise(original : BufferedImage ) : BufferedImage
        }
    }
    package model{
        class Plateau{
            + changerTuile(tuileOriginal : Tuile , tuileNew : Tuile) : Tuile
            + pousserTuile(tuilePousse : Tuile , direction : String) : Tuile
            + tournerTuile(tuileTourne : Tuile , rotation : Integer) : Tuile
        }

        abstract class Tuile <<abstract>>{
        - m_fixe : Boolean
        - m_pattern : Pattern
        + <<create>> Tuile(fixe: Boolean , pattern : Pattern)
        + getObjectif() : Objectifs
        + tournerTuile(tuile : Tuile , orientation : Integer) : Tuile
        }

        enum Pattern{
        ANGLE
        T
        DROIT
        }

        class TuileObjectifs extends Tuile{
            + <<create>> TuileObjectifs(fixe : Boolean , pattern : Pattern , objectifAssocie : Objectifs)
            + getObjectif() : Objectifs
        }
        class TuileLibre extends Tuile{
            + <<create>> TuileLibre(fixe : Boolean , pattern : Pattern)
            + getObjectif() : Objectifs
        }
        class LabyrintheObserver{

        }
        enum Objectifs <<enumeration>>{
            PORTE_AMICALE
            W
            BARBE_DE_Z
            MACHINE_A_CAFE
            LEO_EXAM
            MOULINETTE
            PPP
            RDS
            STAGE
            GANZARSKI
            ECHEC_CONTRE_H
            HERBE
        }

        class Joueur{
            m_objectifRestant : Integer
            m_objectifRecup : Integer
            + <<create>> Joueur(tuile : Tuile , objectif : Objectifs[])
            + verifObjectif() : Boolean
            + getObjectifRecup() : Integer
            + getObjectifRestant() : Integer
            + getTuile() : Tuile
            + validationObjectif()
        }

        TuileObjectifs -> "m_objectifAssocie" Objectifs : > is One
        Joueur o-> "m_listeObjectifs" Objectifs : > has several
        Joueur o-> "m_tuile \n 1" Tuile : > Is on
        Tuile -> "m_pattern" Pattern : > is type
        Plateau -> "m_tuile \n 50" Tuile :  > Have 50
        Plateau -> "m_joueur \n 4" Joueur : < On It


    }
    package view{
        class LabyrintheWindows{}

    }

    LabyrintheWindows -|> LabyrintheObserver

}

@enduml
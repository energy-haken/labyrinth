@startuml
'https://plantuml.com/class-diagram

skinparam style strictuml
skinparam classAttributeIconSize 0
skinparam classFontStyle Bold
hide enum methods


package src{
    class LabyrintheApp{
        static main(args : String[])
    }

    package controller{
        class LabyrintheController{
        + bougerLigne(plateau : Plateau)
        }
        class Background{
        + lancementJeu() : Boolean
        }
    }
    package helpers{
        class ImageHelper{
            + static merge(backgroundPath : String, foregroundPaths : String) : BufferedImage
            + static mergeB(background : BufferedImage, foreground : BufferedImage) : BufferedImage
            + static rotate(original : BufferedImage,angle : double) : BufferedImage
            + static rotateClockwise(original : BufferedImage ) : BufferedImage
            + static rotateCounterClockwise(original : BufferedImage ) : BufferedImage
        }
    }
    package model{
        class Plateau{
            + <<create>> Plateau()
            + pousserTuile( direction : Direction ,colonne : Integer ) : Tuile
            + getTuile() : Tuile
            + getPlateau() : Tuile[][]
            + getJoueur() : Joueur
            + printBoard()
            + checkDirection() : Direction
            + checkPattern() : Pattern
            + checkObjectif-) : Boolean
            + deplacementJoueur(joueur : Joueur , versOu : Direction)
        }

        package tuiles{

        abstract class Tuile <<abstract>>{
        - m_fixe : Boolean
        - m_pattern : Pattern
        - m_coordoneeX : Integer
        - m_coordoneeY : Integer
        - m_name : Integer
        + <<create>> Tuile(fixe: Boolean , pattern : Pattern, direction : Direction , coordoneeX : Integer , coordoneeY : Integer, name : Integer)
        + <<create>> Tuile(fixe: Boolean , pattern : Pattern, direction : Direction , coordoneeX : Integer , coordoneeY : Integer , name : Integer, objectif : Objectif)
        + getObjectif() : Objectif
        + getDirection() : Direction
        + getCoordoneeX() : Integer
        + getCoordoneeY() : Integer
        + getName() : Integer
        + isFixe() : Boolean
        ° checkSortieTuile(direction : Direction) : Boolean
        + tournerTuile(direction : Direction)
        }

        class TuileCoin extends Tuile{
        + <<create>> TuileCoin(fixe: Boolean , direction : Direction , coordoneeX : Integer , coordoneeY : Integer, name : Integer)
        + <<create>> TuileCoin(fixe: Boolean , direction : Direction , coordoneeX : Integer , coordoneeY : Integer , name : Integer, objectif : Objectif)
        + checkSortieTuile(direction : Direction) : Boolean
        }

        class TuileDroit extends Tuile{
        + <<create>> TuileDroit(fixe: Boolean , direction : Direction , coordoneeX : Integer , coordoneeY : Integer, name : Integer)
        + <<create>> TuileDroit(fixe: Boolean , direction : Direction , coordoneeX : Integer , coordoneeY : Integer , name : Integer, objectif : Objectif)
        + checkSortieTuile(direction : Direction) : Boolean
        }

        class TuileT extends Tuile{
        + <<create>> TuileT(fixe: Boolean , direction : Direction , coordoneeX : Integer , coordoneeY : Integer, name : Integer)
        + <<create>> TuileT(fixe: Boolean , direction : Direction , coordoneeX : Integer , coordoneeY : Integer , name : Integer, objectif : Objectif)
        + checkSortieTuile(direction : Direction) : Boolean
        }

        enum Pattern{
        ANGLE
        T
        DROIT
        }

       }
        enum Objectif <<enumeration>>{
            PORTE_AMICALE
            W
            BARBE_DE_Z
            MACHINE_A_CAFE
            LEO_EXAM
            MOULINETTE
            PPP
            RDS
            STAGE
            GANZARSKI
            ECHEC_CONTRE_H
            HERBE
            ...
        }

        class Joueur{
            - m_objectifRestant : Integer
            - m_objectifRecup : Integer
            - m_couleur : String
            + <<create>> Joueur(tuile : Tuile , objectif : Objectif[])
            + verifObjectif() : Boolean
            + getObjectifRecup() : Integer
            + getObjectifRestant() : Integer
            + getTuile() : Tuile
            + getCouleur() : String
            + setTuile(tuile : Tuile)
            + validationObjectif()
        }

        TuileObjectifs -> "m_objectifAssocie" Objectif : > is One
        Joueur o-> "m_listeObjectifs" Objectif : > has several
        Joueur o-> "m_tuile \n 1" Tuile : > Is on
        Tuile -> "m_pattern" Pattern : > is type
        Plateau o-> "\n m_plateau \n 49" Tuile :  > Have 49 (liste de 7 liste de 7 tuiles)
        Plateau o-> "m_tuile \n" Tuile : Have one extra
        Plateau -> "m_joueur \n 4" Joueur : < On It


    }
    package view{

        class LabyrintheMainWindow{
            + <<create>> LabyrintheMainWindow()
            + getPlateau() : Plateau
        }
        class PlateauWindow{
            + <<create>> PlateauWindow()
            + getPlateauModel() : Plateau
            + loadImage(path : String) : BufferedImage
            + loadPlayers(joueur : Joueur)
            + updateMaze(direction : Direction, index : Integer)
        }
    }



}

@enduml